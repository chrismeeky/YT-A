# Copy this file to .env.local and fill in your keys.
# All variables are prefixed with NEXT_PUBLIC_ so they are available on both
# the server (API routes) and the client (browser).

# ─── Beta / hosted mode ───────────────────────────────────────────────────────
# Set to "true" on Vercel to lock API key fields in Settings and use the values
# below instead of user-supplied keys. Leave unset (or "false") for self-hosted.
NEXT_PUBLIC_BETA_MODE=false

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# Required for channel analysis and script generation.
# Get a key at https://console.anthropic.com
NEXT_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...

# ─── YouTube Data API ─────────────────────────────────────────────────────────
# Required for fetching channel videos and research search.
# Enable "YouTube Data API v3" at https://console.cloud.google.com
NEXT_PUBLIC_YOUTUBE_API_KEY=AIza...

# ─── ElevenLabs ───────────────────────────────────────────────────────────────
# Required for scene audio generation.
# Get a key at https://elevenlabs.io
NEXT_PUBLIC_ELEVENLABS_API_KEY=sk_...
# Voice ID to use by default. Find IDs in the ElevenLabs dashboard.
# Default below is "Rachel" — a general-purpose voice.
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── Pexels ───────────────────────────────────────────────────────────────────
# Required for stock photo / video search per scene.
# Free key (200 req/hour) at https://www.pexels.com/api
NEXT_PUBLIC_PEXELS_API_KEY=...

# ─── Supabase (usage tracking & auth) ────────────────────────────────────────
# Project URL and anon key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Local storage (self-hosted only) ─────────────────────────────────────────
# Directory where projects, analyses, and scripts are stored on disk.
# Defaults to ~/Documents/YoutubeAnalyzer — not used on Vercel.
# STORAGE_PATH=/Users/yourname/Documents/YoutubeAnalyzer
